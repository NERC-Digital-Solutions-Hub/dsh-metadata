etricObjectTypeCode></geometricObjectType><geometricObjectCount><gco:Integer>32844</gco:Integer></geometricObjectCount></MD_GeometricObjects></geometricObjects></MD_VectorSpatialRepresentation></spatialRepresentationInfo><referenceSystemInfo><MD_ReferenceSystem><referenceSystemIdentifier><RS_Identifier><code><gco:CharacterString>3857</gco:CharacterString></code><codeSpace><gco:CharacterString>EPSG</gco:CharacterString></codeSpace><version><gco:CharacterString>6.18.3(9.3.1.2)</gco:CharacterString></version></RS_Identifier></referenceSystemIdentifier></MD_ReferenceSystem></referenceSystemInfo><identificationInfo><MD_DataIdentification><citation><CI_Citation><title><gco:CharacterString>EN_LSOA_2011_BFC_V3_2022_CJ</gco:CharacterString></title><date gco:nilReason="missing" /><presentationForm><CI_PresentationFormCode codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#CI_PresentationFormCode" codeListValue="mapDigital" codeSpace="ISOTC211/19115">mapDigital</CI_PresentationFormCode></presentationForm></CI_Citation></citation><abstract><gco:CharacterString>This dataset provides a comprehensive analysis of various socio-economic and environmental factors across Lower Layer Super Output Areas (LSOAs) in England. Key fields include identifiers such as 'LSOA11CD' and 'LSOA11NM' for LSOA codes and names, respectively. The dataset encompasses indices measuring sensitivity, inability to prepare, respond, and recover, as well as enhanced exposure, contributing to the Socio-Spatial Flood Vulnerability Index (SSFVI) and the Socio-Spatial Heat Vulnerability Index (SSHVI). Demographic data covers population counts and exposure metrics, while vulnerability indicators address aspects like age, health, income, property tenure, language proficiency, internet access, local knowledge, social networks, mobility, crime, and access to services such as pharmacies and healthcare facilities. Environmental variables include housing characteristics, urban cover, greenspace availability, and climate-related metrics like temperature extremes under various warming scenarios. The dataset also provides Z-scores for numerous variables, facilitating comparative analysis across regions.</gco:CharacterString></abstract><purpose><gco:CharacterString>This dataset analyzes socio-economic and environmental factors across English LSOAs, highlighting vulnerabilities to flood and heat risks through indices like SSFVI and SSHVI. It includes demographic, health, income, housing, mobility, and climate-related metrics, enabling comparative regional analysis using Z-scores.</gco:CharacterString></purpose><spatialRepresentationType><MD_SpatialRepresentationTypeCode codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_SpatialRepresentationTypeCode" codeListValue="vector" codeSpace="ISOTC211/19115">vector</MD_SpatialRepresentationTypeCode></spatialRepresentationType><language><LanguageCode codeList="http://www.loc.gov/standards/iso639-2/php/code_list.php" codeListValue="eng" codeSpace="ISO639-2">eng</LanguageCode></language><characterSet><MD_CharacterSetCode codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_CharacterSetCode" codeListValue="utf8" codeSpace="ISOTC211/19115">utf8</MD_CharacterSetCode></characterSet><environmentDescription><gco:CharacterString>Esri ArcGIS 13.1.3.41833</gco:CharacterString></environmentDescription><extent><EX_Extent><geographicElement><EX_GeographicBoundingBox><extentTypeCode><gco:Boolean>true</gco:Boolean></extentTypeCode><westBoundLongitude><gco:Decimal>-6.418623</gco:Decimal></westBoundLongitude><eastBoundLongitude><gco:Decimal>1.763571</gco:Decimal></eastBoundLongitude><southBoundLatitude><gco:Decimal>49.864679</gco:Decimal></southBoundLatitude><northBoundLatitude><gco:Decimal>55.811069</gco:Decimal></northBoundLatitude></EX_GeographicBoundingBox></geographicElement></EX_Extent></extent></MD_DataIdentification></identificationInfo><distributionInfo><MD_Distribution><distribut